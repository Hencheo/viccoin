{
  "hosting": {
    "public": "frontend/web-build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "emulators": {
      "hosting": {
        "port": 5000
      }
    }
  }
} 