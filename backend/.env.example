SECRET_KEY=sua-chave-secreta-aqui
DEBUG=False
# Força uso de autenticação real do Firebase mesmo em modo de DEBUG
FIREBASE_REAL_AUTH=True
ALLOWED_HOSTS=localhost,127.0.0.1,viccoin-backend.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://viccoin.onrender.com
DATABASE_URL=sqlite:///db.sqlite3

# Firebase environment variables
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=seu-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=seu-firebase-private-key-id
FIREBASE_PRIVATE_KEY=sua-firebase-private-key
FIREBASE_CLIENT_EMAIL=seu-firebase-client-email
FIREBASE_CLIENT_ID=seu-firebase-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=sua-firebase-client-x509-cert-url
FIREBASE_UNIVERSE_DOMAIN=googleapis.com 